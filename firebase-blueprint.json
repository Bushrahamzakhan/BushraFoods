{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["buyer", "seller", "admin", "vendor", "customer", "investor", "moderator", "support"] },
        "status": { "type": "string" },
        "storeName": { "type": "string" },
        "storeDescription": { "type": "string" },
        "profileImage": { "type": "string" },
        "coverImage": { "type": "string" },
        "lastShippingDetails": { "type": "object" },
        "wishlist": { "type": "array", "items": { "type": "string" } },
        "isTopRated": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "paymentMethods": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Marketplace product listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "integer" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isHalalCertified": { "type": "boolean" },
        "availableCountries": { "type": "array", "items": { "type": "string" } },
        "availableCities": { "type": "array", "items": { "type": "string" } },
        "variationTypes": { "type": "array" },
        "variationCombinations": { "type": "array" },
        "originCountry": { "type": "string" },
        "freshness": { "type": "string" },
        "groupPrice": { "type": "number" },
        "targetMembers": { "type": "integer" },
        "availabilityScope": { "type": "string", "enum": ["global", "country", "local"] },
        "availabilityDescription": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "vendorId", "vendorName", "name", "price", "currency", "category", "imageUrl", "stock", "isHalalCertified", "availabilityScope", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Marketplace transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "status": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "totalAmount": { "type": "number" },
        "currency": { "type": "string" },
        "items": { "type": "array" },
        "shippingDetails": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "paymentReceipt": { "type": "object" },
        "vendorPaymentDetails": { "type": "object" },
        "history": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerId", "customerName", "vendorId", "vendorName", "status", "paymentStatus", "totalAmount", "currency", "items", "shippingDetails", "paymentMethod", "history", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review and rating",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userProfileImage": { "type": "string" },
        "productId": { "type": "string" },
        "vendorId": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "isVerifiedPurchase": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "approved", "flagged"] },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "rating", "comment", "isVerifiedPurchase", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["order", "payment", "system", "message", "approval"] },
        "orderId": { "type": "string" },
        "link": { "type": "string" },
        "isRead": { "type": "boolean" },
        "isArchived": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message", "type", "isRead", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Chat conversation metadata",
      "type": "object",
      "properties": {
        "otherUserId": { "type": "string" },
        "otherUserName": { "type": "string" },
        "otherUserProfileImage": { "type": "string" },
        "lastMessage": { "type": "object" },
        "unreadCount": { "type": "integer" }
      },
      "required": ["otherUserId", "otherUserName", "unreadCount"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "receiverId", "content", "isRead", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Product subscription",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "productImageUrl": { "type": "string" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
        "quantity": { "type": "integer" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "paused", "cancelled"] },
        "nextDelivery": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerId", "productId", "productName", "vendorId", "vendorName", "frequency", "quantity", "price", "currency", "status", "nextDelivery", "createdAt"]
    },
    "GroupPurchase": {
      "title": "GroupPurchase",
      "description": "Group purchase opportunity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "productImageUrl": { "type": "string" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "targetMembers": { "type": "integer" },
        "currentMembers": { "type": "integer" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["open", "completed", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "members": { "type": "array" }
      },
      "required": ["id", "productId", "productName", "vendorId", "vendorName", "targetMembers", "currentMembers", "price", "currency", "expiresAt", "status", "createdAt"]
    },
    "InvestmentOpportunity": {
      "title": "InvestmentOpportunity",
      "description": "Investment opportunity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "vendorId": { "type": "string" },
        "fundingGoal": { "type": "number" },
        "currentFunding": { "type": "number" },
        "totalUnits": { "type": "integer" },
        "profitSharingPct": { "type": "number" },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "tiers": { "type": "array" }
      },
      "required": ["id", "productId", "productName", "vendorId", "fundingGoal", "currentFunding", "totalUnits", "profitSharingPct", "riskLevel", "status", "createdAt"]
    },
    "Investment": {
      "title": "Investment",
      "description": "User investment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "opportunityId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "investorId": { "type": "string" },
        "tierId": { "type": "string" },
        "tierName": { "type": "string" },
        "amount": { "type": "number" },
        "expectedReturnPct": { "type": "number" },
        "earnedSoFar": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "opportunityId", "productId", "productName", "investorId", "tierId", "tierName", "amount", "expectedReturnPct", "earnedSoFar", "status", "createdAt"]
    },
    "InvestorWallet": {
      "title": "InvestorWallet",
      "description": "User investment wallet",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "balance": { "type": "number" },
        "totalEarned": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "transactions": { "type": "array" }
      },
      "required": ["userId", "balance", "totalEarned", "updatedAt"]
    },
    "VendorApplication": {
      "title": "VendorApplication",
      "description": "Application to become a vendor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "businessName": { "type": "string" },
        "businessDescription": { "type": "string" },
        "businessAddress": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "reviewedBy": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "userEmail", "businessName", "businessDescription", "businessAddress", "phoneNumber", "status", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "integer" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "isActive", "createdAt"]
    },
    "Media": {
      "title": "Media",
      "description": "Image data stored as Base64",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "folder": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploadedByEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "fileName": { "type": "string" }
      },
      "required": ["id", "url", "uploadedBy", "createdAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "System audit log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string" },
        "performedBy": { "type": "string" },
        "performedByName": { "type": "string" },
        "targetUserId": { "type": "string" },
        "targetUserName": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "action", "performedBy", "performedByName", "targetUserId", "targetUserName", "createdAt"]
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "description": "Global system configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "onlinePaymentsEnabled": { "type": "boolean" },
        "stripeEnabled": { "type": "boolean" },
        "paypalEnabled": { "type": "boolean" },
        "twoCheckoutEnabled": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "onlinePaymentsEnabled", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profile document" },
    "/products/{productId}": { "schema": "Product", "description": "Product listing document" },
    "/orders/{orderId}": { "schema": "Order", "description": "Order transaction document" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Product review document" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notification document" },
    "/conversations/{conversationId}": { "schema": "Conversation", "description": "Chat conversation document" },
    "/conversations/{conversationId}/messages/{messageId}": { "schema": "Message", "description": "Chat message document" },
    "/subscriptions/{subscriptionId}": { "schema": "Subscription", "description": "Product subscription document" },
    "/groupPurchases/{purchaseId}": { "schema": "GroupPurchase", "description": "Group purchase document" },
    "/investmentOpportunities/{opportunityId}": { "schema": "InvestmentOpportunity", "description": "Investment opportunity document" },
    "/investments/{investmentId}": { "schema": "Investment", "description": "User investment document" },
    "/investorWallets/{userId}": { "schema": "InvestorWallet", "description": "User investment wallet document" },
    "/vendorApplications/{applicationId}": { "schema": "VendorApplication", "description": "Vendor application document" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Product category document" },
    "/media/{mediaId}": { "schema": "Media", "description": "Media storage document" },
    "/auditLogs/{logId}": { "schema": "AuditLog", "description": "System audit log document" },
    "/systemConfig/{configId}": { "schema": "SystemConfig", "description": "System configuration document" }
  }
}
